	$(SDK_LIB_PATH)\ntdll.lib \
	$(SDK_LIB_PATH)\user32.lib \
	$(WINDOWS_LIB_PATH)\user32p.lib \
	$(SDK_LIB_PATH)\htmlhelp.lib \
	$(SDK_LIB_PATH)\winsta.lib \
	$(SDK_LIB_PATH)\mincore.lib

