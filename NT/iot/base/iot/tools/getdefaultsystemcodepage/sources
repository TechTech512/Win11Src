TARGETNAME=GetDefaultSystemCodePage
TARGETPATH=obj
TARGETTYPE=PROGRAM
USE_MSVCRT=1
EXPECTED_WINVER=10.00

INCLUDES=.;$(MINWIN_PRIV_SDK_INC_PATH)
SOURCES=getdefaultsystemcodepage.cpp \
		defaultresource.rc

C_DEFINES=-DSECURITY_WIN32 -DUNICODE -D_UNICODE -DSTRICT -DWINVER=0x0A00 -D_WIN32_WINNT=0x0A00

CXXFLAGS=$(CXXFLAGS) /Zc:sizedDealloc

LINKENTRY=wmainCRTStartup

UMTYPE=console
UMENTRY=wmain
TARGETLIBS= \
	$(SDK_LIB_PATH)\msvcrt.lib \
	$(SDK_LIB_PATH)\onecoreuap.lib

NT_SIGNCODE=1
