TARGETNAME=hh
TARGETPATH=obj
TARGETTYPE=PROGRAM
USE_MSVCRT=1
EXPECTED_WINVER=10.0

INCLUDES=.;$(ENDUSER_INC_PATH)
SOURCES=init.c \
		hh.rc

C_DEFINES=-DSECURITY_WIN32 -DUNICODE -D_UNICODE -DSTRICT -DWINVER=0x0A00 -D_WIN32_WINNT=0x0A00

CXXFLAGS=$(CXXFLAGS) /Zc:sizedDealloc

LINKENTRY=WinMainCRTStartup

UMTYPE=windows
UMENTRY=winmain
TARGETLIBS= \
	$(SDK_LIB_PATH)\advapi32.lib \
	$(SDK_LIB_PATH)\kernel32.lib \
	$(SDK_LIB_PATH)\user32.lib

# Fusionized
SXS_MANIFEST_RESOURCE_ID=1
SXS_APPLICATION_MANIFEST=Hh.Manifest
SXS_ASSEMBLY_NAME=Microsoft.Windows.Help.HH
SXS_NO_BINPLACE=1
SXS_MANIFEST_IN_RESOURCES=1
